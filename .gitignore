# ══════════════════════════════════════════════
#  REMEHBS — .gitignore
# ══════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python / Django ───────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Django
backend/db.sqlite3
backend/staticfiles/
backend/media/
*.log

# Celery
celerybeat-schedule
celerybeat.pid

# ── Node / Frontend ──────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDE / OS ─────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
Desktop.ini

# ── Coverage & Testing ──────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ── Misc ─────────────────────────────────────
*.bak
*.tmp
*.swp
*~

# ── Generated submissions exports ───────────
*.pdf
# Programme scientifique JSP (copies servies par le frontend)
!frontend/public/programme-jsp-2025/**/*.pdf
soumissions_approuvees_fichiers_*/
