# ──────────────────────────────────────────────
#  REMEHBS API — Variables d'environnement
# ──────────────────────────────────────────────

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (SQLite en dev, PostgreSQL en prod)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/remehbs

# CinetPay
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_SECRET_KEY=your_cinetpay_secret_key
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# Resend (emails transactionnels)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@remehbs-bf.org

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Frontend URL (pour les redirections paiement)
FRONTEND_URL=http://localhost:5173
