# ══════════════════════════════════════════════
#  REMEHBS API — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# Django
SECRET_KEY=change-me-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# SQLite (dev) :
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (prod) :
# DATABASE_URL=postgresql://user:password@host:5432/remehbs

# CORS — origines supplémentaires (séparées par des virgules)
# localhost:5173 et localhost:3000 sont inclus par défaut
CORS_ALLOWED_ORIGINS=https://remehbs-bf.org,https://www.remehbs-bf.org

# CinetPay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# Limites upload backend
MAX_PROFILE_PHOTO_SIZE=5242880
MAX_ABSTRACT_FILE_SIZE=10485760

# Resend (emails transactionnels)
RESEND_API_KEY=
EMAIL_FROM=noreply@remehbs-bf.org

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Frontend URL (pour redirections paiement + emails)
FRONTEND_URL=http://localhost:5173

# Monitoring (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
